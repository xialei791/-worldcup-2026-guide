/* 日历页面样式 */
.container {
  background: linear-gradient(180deg, #f0f7f0 0%, #e8f5e9 100%);
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 日历头部 */
.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 40rpx;
  background: linear-gradient(135deg, #1a5f2a 0%, #2e7d32 100%);
}

.month-nav {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
}

.nav-arrow {
  color: #fff;
  font-size: 40rpx;
  font-weight: bold;
}

.current-month {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

/* 星期标题 */
.week-header {
  display: flex;
  background: #fff;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.week-day {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.week-day:first-child,
.week-day:last-child {
  color: #e74c3c;
}

/* 日历网格 */
.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  background: #fff;
  padding: 10rpx;
}

.day-cell {
  width: calc(100% / 7);
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.day-cell.empty {
  background: #f9f9f9;
}

.day-num {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 今天标记 */
.day-cell.today {
  background: #e8f5e9;
}

.day-cell.today .day-num {
  color: #1a5f2a;
  font-weight: bold;
}

/* 赛事期间 */
.day-cell.in-tournament {
  background: linear-gradient(180deg, #fff 0%, #f0f8f0 100%);
}

/* 选中状态 */
.day-cell.selected {
  background: #1a5f2a;
  border-radius: 12rpx;
  transform: scale(0.95);
}

.day-cell.selected .day-num {
  color: #fff;
}

.day-cell.selected .match-count {
  color: rgba(255,255,255,0.9);
}

/* 比赛标记点 */
.match-dots {
  display: flex;
  gap: 4rpx;
  margin-top: 6rpx;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
}

.dot.regular {
  background: #4caf50;
}

.dot.important {
  background: #ff9800;
  width: 10rpx;
  height: 10rpx;
}

.match-count {
  font-size: 18rpx;
  color: #666;
  margin-top: 4rpx;
}

/* 日期详情 */
.date-detail {
  margin: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.date-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.selected-date {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a5f2a;
}

.match-total {
  font-size: 24rpx;
  color: #4caf50;
  background: #e8f5e9;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.match-total.no-match {
  color: #999;
  background: #f5f5f5;
}

.view-all {
  font-size: 26rpx;
  color: #1a5f2a;
}

/* 推荐比赛 */
.recommend-section {
  margin-bottom: 30rpx;
}

.recommend-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.star {
  font-size: 32rpx;
}

.recommend-match {
  background: linear-gradient(135deg, #1a5f2a 0%, #2e7d32 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  color: #fff;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); box-shadow: 0 4rpx 20rpx rgba(26,95,42,0.3); }
  50% { transform: scale(1.02); box-shadow: 0 8rpx 30rpx rgba(26,95,42,0.4); }
}

.match-time {
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  opacity: 0.95;
}

.match-teams-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.team-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.recommend-match .team-flag {
  width: 80rpx;
  height: 60rpx;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.2);
}

.recommend-match .team-name {
  font-size: 28rpx;
  font-weight: 500;
}

.vs {
  font-size: 36rpx;
  font-weight: bold;
  opacity: 0.9;
}

.match-group {
  text-align: center;
  font-size: 24rpx;
  opacity: 0.8;
  background: rgba(255,255,255,0.2);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  display: inline-block;
  margin: 0 auto;
}

/* 其他比赛 */
.other-matches {
  margin-top: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: block;
}

.match-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.item-time {
  font-size: 24rpx;
  color: #1a5f2a;
  font-weight: 500;
  min-width: 80rpx;
}

.item-teams {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1;
  justify-content: center;
}

.small-flag {
  width: 40rpx;
  height: 30rpx;
  border-radius: 4rpx;
}

.small-name {
  font-size: 24rpx;
  color: #333;
}

.small-vs {
  font-size: 20rpx;
  color: #999;
  margin: 0 10rpx;
}

.item-group {
  font-size: 22rpx;
  color: #999;
  min-width: 80rpx;
  text-align: right;
}

/* 图例 */
.calendar-legend {
  display: flex;
  justify-content: space-around;
  margin: 20rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: #666;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

.legend-dot.today {
  background: #e8f5e9;
  border: 2rpx solid #1a5f2a;
}

.legend-dot.in-tournament {
  background: #f0f8f0;
  border: 2rpx solid #4caf50;
}

.legend-dot.has-match {
  background: #4caf50;
}

.legend-dot.important {
  background: #ff9800;
}
