<!-- 赛程页面 -->
<view class="container">
  <!-- 阶段选择 -->
  <scroll-view scroll-x class="stage-tabs">
    <view class="stage-item {{currentStage === item.key ? 'active' : ''}}"
          wx:for="{{stages}}"
          wx:key="key"
          data-key="{{item.key}}"
          bindtap="switchStage">
      {{item.name}}
    </view>
  </scroll-view>

  <!-- 日期选择器 -->
  <scroll-view scroll-x class="date-tabs" wx:if="{{currentStage === 'group'}}">
    <view class="date-item {{currentDate === item.date ? 'active' : ''}}"
          wx:for="{{dates}}"
          wx:key="date"
          data-date="{{item.date}}"
          bindtap="switchDate">
      <text class="date-day">{{item.day}}</text>
      <text class="date-week">{{item.week}}</text>
    </view>
  </scroll-view>

  <!-- 比赛列表 -->
  <view class="match-list">
    <block wx:if="{{matches.length > 0}}">
      <view class="match-card" wx:for="{{matches}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="match-header">
          <text class="match-time">{{item.time}}</text>
          <text class="match-group">{{item.group || item.stage}}</text>
          <view wx:if="{{item.status === 'live'}}" class="live-indicator">
            <view class="live-dot"></view>
            <text>{{item.minute}}'</text>
          </view>
          <text wx:elif="{{item.status === 'finished'}}" class="finished-tag">已结束</text>
          <text wx:else class="upcoming-tag">未开始</text>
        </view>

        <view class="match-body">
          <view class="team home">
            <image class="team-flag" src="{{item.homeFlag}}" mode="aspectFit"/>
            <text class="team-name">{{item.homeTeam}}</text>
          </view>

          <view class="match-score">
            <block wx:if="{{item.status !== 'upcoming'}}">
              <text class="score-num">{{item.homeScore}} - {{item.awayScore}}</text>
            </block>
            <block wx:else>
              <text class="vs-text">VS</text>
            </block>
          </view>

          <view class="team away">
            <image class="team-flag" src="{{item.awayFlag}}" mode="aspectFit"/>
            <text class="team-name">{{item.awayTeam}}</text>
          </view>
        </view>

        <view class="match-footer">
          <text class="stadium">📍 {{item.stadium}}</text>
          <text class="city">{{item.city}}</text>
        </view>
      </view>
    </block>
    <view wx:else class="empty">
      <text class="empty-text">暂无比赛数据</text>
    </view>
  </view>
</view>
