/* 首页样式 - 高级感动画版 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f7f0 0%, #e8f5e9 50%, #f0f7f0 100%);
  padding-bottom: 40rpx;
  position: relative;
  overflow: hidden;
}

/* 倒计时横幅 */
.countdown-banner {
  position: relative;
  height: 400rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.countdown-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #1a5f2a 0%, #2e7d32 30%, #1a5f2a 100%);
}

.countdown-bg::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><circle cx="50" cy="50" r="40" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="0.5"/></svg>');
  background-size: 100rpx 100rpx;
  animation: bgMove 20s linear infinite;
}

@keyframes bgMove {
  0% { background-position: 0 0; }
  100% { background-position: 100rpx 100rpx; }
}

.countdown-content {
  position: relative;
  z-index: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  padding: 40rpx;
}

.countdown-label {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  text-shadow: 0 4rpx 10rpx rgba(0,0,0,0.3);
  animation: titleGlow 2s ease-in-out infinite;
}

@keyframes titleGlow {
  0%, 100% { text-shadow: 0 4rpx 10rpx rgba(0,0,0,0.3); }
  50% { text-shadow: 0 4rpx 20rpx rgba(255,255,255,0.3), 0 0 30rpx rgba(255,255,255,0.2); }
}

.countdown-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 30rpx;
}

.countdown-timer {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.time-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.time-num {
  font-size: 56rpx;
  font-weight: bold;
  background: rgba(255,255,255,0.2);
  padding: 15rpx 20rpx;
  border-radius: 16rpx;
  min-width: 70rpx;
  text-align: center;
  backdrop-filter: blur(10rpx);
  animation: numberPulse 1s ease-in-out infinite;
}

@keyframes numberPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.02); }
}

.time-unit {
  font-size: 24rpx;
  margin-top: 10rpx;
  opacity: 0.8;
}

.time-separator {
  font-size: 40rpx;
  font-weight: bold;
  opacity: 0.7;
  animation: separatorBlink 1s ease-in-out infinite;
}

@keyframes separatorBlink {
  0%, 100% { opacity: 0.7; }
  50% { opacity: 1; }
}

.countdown-date {
  font-size: 26rpx;
  opacity: 0.85;
  background: rgba(255,255,255,0.15);
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
}

/* 快捷入口 */
.quick-menu {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 20rpx;
  margin: 0 20rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  transition: transform 0.3s;
}

.menu-item:active {
  transform: scale(0.95);
}

.menu-icon {
  width: 90rpx;
  height: 90rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.1);
  animation: iconFloat 3s ease-in-out infinite;
}

.menu-icon.schedule { background: linear-gradient(135deg, #e3f2fd, #bbdefb); }
.menu-icon.calendar { background: linear-gradient(135deg, #f3e5f5, #e1bee7); }
.menu-icon.teams { background: linear-gradient(135deg, #e8f5e9, #c8e6c9); }
.menu-icon.stadiums { background: linear-gradient(135deg, #fff3e0, #ffe0b2); }
.menu-icon.news { background: linear-gradient(135deg, #fce4ec, #f8bbd9); }

@keyframes iconFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-5rpx); }
}

.menu-text {
  font-size: 24rpx;
  color: #666;
}

/* 卡片通用样式 */
.card {
  margin: 0 20rpx 20rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  animation: cardSlideUp 0.5s ease-out;
}

@keyframes cardSlideUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25rpx;
}

.title-section {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.card-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.live-indicator {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #ff4444;
  background: #ffebee;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
}

.live-dot {
  width: 16rpx;
  height: 16rpx;
  background: #ff4444;
  border-radius: 50%;
  animation: liveBlink 1s infinite;
}

@keyframes liveBlink {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.2); }
}

.more {
  font-size: 26rpx;
  color: #1a5f2a;
}

/* 今日赛事 */
.match-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.match-item {
  background: linear-gradient(135deg, #f8f9fa 0%, #fff 100%);
  border-radius: 20rpx;
  padding: 25rpx;
  border-left: 6rpx solid #ddd;
  animation: itemSlideIn 0.4s ease-out both;
  animation-delay: inherit;
}

@keyframes itemSlideIn {
  from {
    opacity: 0;
    transform: translateX(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.match-item.live {
  border-left-color: #ff4444;
  background: linear-gradient(135deg, #fff5f5 0%, #fff 100%);
}

.match-item.finished {
  border-left-color: #4caf50;
}

.match-status-bar {
  display: inline-block;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.match-status-bar.live {
  background: #ff4444;
  color: #fff;
  animation: statusPulse 1.5s infinite;
}

@keyframes statusPulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(255,68,68,0.4); }
  50% { box-shadow: 0 0 0 10rpx rgba(255,68,68,0); }
}

.match-status-bar.finished {
  background: #e8f5e9;
  color: #4caf50;
}

.match-status-bar:not(.live):not(.finished) {
  background: #e3f2fd;
  color: #2196f3;
}

.match-teams {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.team {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex: 1;
}

.team-flag {
  width: 70rpx;
  height: 50rpx;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.team-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.vs {
  flex: 0 0 120rpx;
  text-align: center;
}

.score {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.score.live-score {
  color: #ff4444;
  animation: scoreGlow 1s infinite;
}

@keyframes scoreGlow {
  0%, 100% { text-shadow: 0 0 0 transparent; }
  50% { text-shadow: 0 0 20rpx rgba(255,68,68,0.5); }
}

.vs-text {
  font-size: 32rpx;
  color: #999;
  font-weight: bold;
}

.match-stadium {
  text-align: center;
}

.stadium {
  font-size: 24rpx;
  color: #666;
}

.no-match {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}

.no-match-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

/* 积分榜卡片 */
.standings-card {
  overflow: hidden;
}

.standing-tabs {
  display: flex;
  margin-bottom: 25rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 6rpx;
}

.standing-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #666;
  border-radius: 10rpx;
  transition: all 0.3s;
}

.standing-tab.active {
  background: #fff;
  color: #1a5f2a;
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

/* 小组标签 */
.group-tabs {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.tab-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 15rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #1a5f2a, #2e7d32);
  color: #fff;
  box-shadow: 0 4rpx 15rpx rgba(26,95,42,0.3);
}

/* 积分榜表格 */
.standings-table {
  background: #f8f9fa;
  border-radius: 16rpx;
  overflow: hidden;
}

.table-header {
  display: flex;
  padding: 20rpx;
  background: linear-gradient(135deg, #1a5f2a, #2e7d32);
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.table-row {
  display: flex;
  padding: 20rpx;
  align-items: center;
  border-bottom: 1rpx solid #eee;
  animation: rowSlideIn 0.4s ease-out both;
  animation-delay: inherit;
  transition: all 0.3s;
}

@keyframes rowSlideIn {
  from {
    opacity: 0;
    transform: translateX(-30rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.table-row.qualified {
  background: linear-gradient(90deg, rgba(76,175,80,0.1) 0%, transparent 100%);
}

.table-row:last-child {
  border-bottom: none;
}

.col-rank {
  width: 80rpx;
  text-align: center;
}

.rank-num {
  display: inline-block;
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: bold;
}

.rank-1 {
  background: linear-gradient(135deg, #ffd700, #ffb300);
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(255,193,7,0.4);
}

.rank-2 {
  background: linear-gradient(135deg, #c0c0c0, #9e9e9e);
  color: #fff;
}

.rank-3 {
  background: linear-gradient(135deg, #cd7f32, #a1887f);
  color: #fff;
}

.rank-num:not(.rank-1):not(.rank-2):not(.rank-3) {
  background: #e0e0e0;
  color: #666;
}

.col-team {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.team-flag-small {
  width: 40rpx;
  height: 30rpx;
  border-radius: 4rpx;
}

.team-name-text {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.col-gf, .col-ga, .col-mp {
  width: 60rpx;
  text-align: center;
  font-size: 24rpx;
  color: #666;
}

.col-group {
  width: 50rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

.col-pts {
  width: 70rpx;
  text-align: center;
}

.pts-num, .pts-num-large {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a5f2a;
}

.pts-num-large {
  font-size: 36rpx;
}

.pts-label {
  font-size: 20rpx;
  color: #999;
}

/* 总积分榜 */
.overall-table {
  background: #f8f9fa;
  border-radius: 16rpx;
  overflow: hidden;
}

.overall-header {
  display: flex;
  padding: 20rpx;
  background: linear-gradient(135deg, #1a5f2a, #2e7d32);
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.overall-row {
  display: flex;
  padding: 20rpx;
  align-items: center;
  border-bottom: 1rpx solid #eee;
  animation: rowSlideIn 0.4s ease-out both;
  animation-delay: inherit;
}

.overall-row.top3 {
  background: linear-gradient(90deg, rgba(255,215,0,0.15) 0%, transparent 100%);
}

.overall-row.qualified {
  background: linear-gradient(90deg, rgba(76,175,80,0.1) 0%, transparent 100%);
}

.rank-badge {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  font-size: 26rpx;
}

.rank-badge.rank-1 {
  background: linear-gradient(135deg, #ffd700, #ffb300);
  color: #fff;
}

.rank-badge.rank-2 {
  background: linear-gradient(135deg, #c0c0c0, #9e9e9e);
  color: #fff;
}

.rank-badge.rank-3 {
  background: linear-gradient(135deg, #cd7f32, #a1887f);
  color: #fff;
}

.rank-badge:not(.rank-1):not(.rank-2):not(.rank-3) {
  background: #f5f5f5;
  color: #666;
}

.team-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.team-record {
  font-size: 20rpx;
  color: #999;
}

.table-legend {
  display: flex;
  gap: 30rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 22rpx;
  color: #666;
}

.legend-box {
  width: 24rpx;
  height: 24rpx;
  border-radius: 6rpx;
}

.legend-box.qualified {
  background: rgba(76,175,80,0.2);
}

.legend-box.eliminated {
  background: #f5f5f5;
}

/* 资讯列表 */
.news-list {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}

.news-item {
  display: flex;
  gap: 20rpx;
  animation: itemSlideIn 0.4s ease-out both;
  animation-delay: inherit;
}

.news-image-wrap {
  position: relative;
  width: 200rpx;
  height: 140rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.news-image {
  width: 100%;
  height: 100%;
}

.news-category-tag {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  font-size: 20rpx;
  color: #fff;
  background: rgba(26,95,42,0.85);
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.news-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.news-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.news-meta {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.news-time {
  font-size: 22rpx;
  color: #999;
}

/* 赛事数据统计 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  margin-top: 25rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 25rpx 15rpx;
  background: #f8f9fa;
  border-radius: 20rpx;
  transition: transform 0.3s;
}

.stat-item:active {
  transform: scale(0.95);
}

.stat-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 5rpx;
}

.stat-icon.teams-icon { background: linear-gradient(135deg, #e8f5e9, #c8e6c9); }
.stat-icon.matches-icon { background: linear-gradient(135deg, #fff3e0, #ffe0b2); }
.stat-icon.hosts-icon { background: linear-gradient(135deg, #e3f2fd, #bbdefb); }
.stat-icon.stadiums-icon { background: linear-gradient(135deg, #fce4ec, #f8bbd9); }

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #1a5f2a;
}

.stat-label {
  font-size: 22rpx;
  color: #666;
}

/* 背景装饰 */
.bg-decoration {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: -1;
  overflow: hidden;
}

.football {
  position: absolute;
  font-size: 100rpx;
  opacity: 0.05;
  animation: footballFloat 15s infinite;
}

.football-1 {
  top: 20%;
  left: -10%;
  animation-delay: 0s;
}

.football-2 {
  top: 60%;
  right: -5%;
  animation-delay: 5s;
}

.football-3 {
  bottom: 20%;
  left: 10%;
  animation-delay: 10s;
}

@keyframes footballFloat {
  0%, 100% {
    transform: translateY(0) rotate(0deg);
  }
  50% {
    transform: translateY(-50rpx) rotate(180deg);
  }
}

/* 动画类 */
.animate-fade-in {
  animation: fadeIn 0.5s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
