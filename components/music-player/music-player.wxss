/* 音乐播放器组件样式 */

/* 迷你播放器 */
.mini-player {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 150rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  box-shadow: 0 4rpx 30rpx rgba(0, 0, 0, 0.15);
  backdrop-filter: blur(20rpx);
  z-index: 100;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.mini-player.playing {
  box-shadow: 0 4rpx 30rpx rgba(26, 95, 42, 0.2);
}

.album-cover {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 20rpx;
  animation: rotate 10s linear infinite;
  animation-play-state: paused;
}

.mini-player.playing .album-cover {
  animation-play-state: running;
}

.album-cover image {
  width: 100%;
  height: 100%;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.mini-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.mini-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.mini-artist {
  font-size: 22rpx;
  color: #999;
}

.mini-control {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-icon {
  font-size: 40rpx;
}

/* 全屏播放器 */
.full-player {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.player-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.3;
  filter: blur(40rpx);
}

.player-bg image {
  width: 100%;
  height: 100%;
}

/* 播放器头部 */
.player-header {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 30rpx;
}

.back-btn, .more-btn {
  font-size: 40rpx;
  color: #fff;
  padding: 10rpx;
}

.header-title {
  text-align: center;
}

.playing-from {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

.playlist-name {
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
}

/* 唱片区域 */
.vinyl-area {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.vinyl-container {
  width: 480rpx;
  height: 480rpx;
  position: relative;
}

.vinyl-container.rotating {
  animation: vinylRotate 20s linear infinite;
}

@keyframes vinylRotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.vinyl {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  overflow: hidden;
  border: 20rpx solid rgba(0, 0, 0, 0.3);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.4);
}

.vinyl image {
  width: 100%;
  height: 100%;
}

/* 歌曲信息 */
.song-info {
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 0 60rpx;
  margin-bottom: 40rpx;
}

.song-title {
  display: block;
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.3);
}

.song-artist {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 8rpx;
}

.song-year {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.1);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

/* 进度条 */
.progress-area {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 0 40rpx;
  margin-bottom: 40rpx;
}

.time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  min-width: 60rpx;
  text-align: center;
}

.progress-slider {
  flex: 1;
  margin: 0 20rpx;
}

/* 控制按钮 */
.controls {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 40rpx;
  padding: 0 60rpx;
  margin-bottom: 40rpx;
}

.control-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  transition: all 0.3s;
}

.control-btn text {
  font-size: 36rpx;
}

.control-btn:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.2);
}

.play-btn {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #1a5f2a, #2e7d32);
}

.play-btn text {
  font-size: 56rpx;
}

.mode-btn text, .playlist-btn text {
  font-size: 32rpx;
}

/* 播放列表 */
.playlist-section {
  position: relative;
  z-index: 1;
  flex: 1;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 40rpx 40rpx 0 0;
  overflow: hidden;
}

.playlist-header {
  padding: 30rpx 40rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.playlist-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

.playlist-scroll {
  height: 400rpx;
  padding: 20rpx 0;
}

.playlist-item {
  display: flex;
  align-items: center;
  padding: 20rpx 40rpx;
  transition: all 0.3s;
}

.playlist-item:active {
  background: rgba(255, 255, 255, 0.05);
}

.playlist-item.active {
  background: rgba(26, 95, 42, 0.3);
}

.item-number {
  width: 60rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
}

.playing-icon {
  color: #4caf50;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.item-info {
  flex: 1;
}

.item-title {
  display: block;
  font-size: 28rpx;
  color: #fff;
  margin-bottom: 6rpx;
}

.item-artist {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.item-status {
  width: 60rpx;
  text-align: center;
}

.wave {
  font-size: 28rpx;
  color: #4caf50;
  animation: wave 0.5s infinite alternate;
}

@keyframes wave {
  from { transform: scaleY(1); }
  to { transform: scaleY(1.5); }
}
